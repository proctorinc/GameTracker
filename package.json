{
  "name": "skybo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --import tsx scripts/dev.ts",
    "dev:next": "next dev",
    "db:seed": "node --import tsx scripts/seed-dev.ts",
    "db:seed:staging": "node --import tsx scripts/seed-staging.ts",
    "auth:backfill:clerk": "node --env-file=.env.production --import tsx scripts/backfill-clerk-users.ts",
    "db:repair:guest-merge": "node --import tsx scripts/repair-guest-merge.ts",
    "db:reset": "node --import tsx scripts/reset-dev-db.ts",
    "db:titles:import": "node --import tsx scripts/import-game-titles.ts",
    "bgg:image:resolve": "node --import tsx scripts/resolve-bgg-image.ts",
    "build": "APP_ENV=production next build",
    "start": "APP_ENV=production next start",
    "lint": "eslint",
    "test": "npm run test:ci",
    "test:watch": "vitest --config vitest.component.config.ts",
    "test:coverage": "vitest run --config vitest.unit.config.ts --coverage && vitest run --config vitest.component.config.ts --coverage && vitest run --config vitest.integration.config.ts --coverage",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:component": "vitest run --config vitest.component.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:ci": "npm run test:unit && npm run test:component && npm run test:integration && npm run test:e2e:smoke",
    "staging:ready": "npm run test && npm run build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:test": "node --env-file=.env.test ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:migrate:prod": "node --env-file=.env.production ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@clerk/nextjs": "^7.4.3",
    "@clerk/ui": "^1.15.0",
    "@libsql/client": "^0.17.3",
    "@paralleldrive/cuid2": "^3.3.0",
    "@xyflow/react": "^12.10.2",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dagre": "^0.8.5",
    "drizzle-orm": "^0.45.2",
    "gsap": "^3.15.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-charts": "^3.0.0-beta.57",
    "react-country-state-city": "^1.1.12",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "svix": "^1.95.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vis-network": "^10.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.6",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.1",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
